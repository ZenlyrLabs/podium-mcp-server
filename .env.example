# Required — your Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Optional — GNews API key (https://gnews.io/) for live trending topics.
# If unset, get_trending_topics falls back to Claude-generated suggestions.
GNEWS_API_KEY=

# Optional — port to listen on. Railway sets this automatically.
PORT=3000
